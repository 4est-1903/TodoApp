@model List<TodoApp.Web.Models.TodoViewModel>

@{
    ViewData["Title"] = "Görev Yönetim Merkezi";
    var currentSearch = ViewData["CurrentSearch"]?.ToString();
    var currentFilter = ViewData["CurrentFilter"] as bool?;

    // İstatistikler için minik hesaplamalar
    var totalTasks = Model?.Count ?? 0;
    var completedTasks = Model?.Count(t => t.IsCompleted) ?? 0;
    var pendingTasks = totalTasks - completedTasks;
}

<style>
    .todo-card {
        transition: all 0.3s ease;
        border-radius: 12px;
    }

        .todo-card:hover {
            transform: translateY(-4px);
            /* shadow yerine box-shadow olarak düzeltildi */
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

    .stat-card {
        border-radius: 16px;
        background: linear-gradient(145deg, #ffffff, #f5f7fa);
    }
</style>

<div class="container py-5">

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card stat-card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase text-muted" style="font-size: 0.8rem; font-weight: 700;">Toplam Görev</h6>
                    <h2 class="fw-bold text-dark mb-0">@totalTasks</h2>
                </div>
                <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3">
                    <i class="bi bi-list-task fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase text-muted" style="font-size: 0.8rem; font-weight: 700;">Tamamlananlar</h6>
                    <h2 class="fw-bold text-success mb-0">@completedTasks</h2>
                </div>
                <div class="bg-success bg-opacity-10 text-success p-3 rounded-3">
                    <i class="bi bi-check2-circle fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card border-0 shadow-sm p-3 d-flex flex-row align-items-center justify-content-between">
                <div>
                    <h6 class="text-uppercase text-muted" style="font-size: 0.8rem; font-weight: 700;">Devam Edenler</h6>
                    <h2 class="fw-bold text-warning mb-0">@pendingTasks</h2>
                </div>
                <div class="bg-warning bg-opacity-10 text-warning p-3 rounded-3">
                    <i class="bi bi-clock-history fs-3"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-5">
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg p-4 sticky-top" style="top: 2rem; border-radius: 16px; background-color: #ffffff;">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary text-white p-2 rounded-3 me-3">
                        <i class="bi bi-plus-lg fs-5"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-0">Yeni Görev</h4>
                </div>

                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label text-secondary fw-semibold">Görev Başlığı</label>
                        <input type="text" name="Title" class="form-control form-control-lg border-2 shadow-none" style="border-radius: 10px;" placeholder="Ne yapacaksınız?" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-secondary fw-semibold">Detaylı Açıklama</label>
                        <textarea name="Description" class="form-control border-2 shadow-none" style="border-radius: 10px;" rows="4" placeholder="Göreve dair notlar ekleyin..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow">
                        Oluştur <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-3 mb-4 text-white" style="border-radius: 14px; background-color: #212529;">
                <form method="get" asp-action="Index" class="row g-2 align-items-center">
                    <div class="col-md-6">
                        <div class="input-group">
                            <span class="input-group-text border-0 bg-transparent text-muted"><i class="bi bi-search"></i></span>
                            <input type="text" name="search" class="form-control border-0 bg-transparent text-white placeholder-muted shadow-none" placeholder="Anahtar kelime ile ara..." value="@currentSearch" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <select name="isCompleted" class="form-select border-0 bg-secondary bg-opacity-25 text-white shadow-none" style="border-radius: 8px;">
                            <!option value="" @(currentFilter == null ? "selected" : "")>🔍 Tüm Durumlar</!option>
                            <!option value="true" @(currentFilter == true ? "selected" : "")>🟢 Sadece Tamamlananlar</!option>
                            <!option value="false" @(currentFilter == false ? "selected" : "")>🟡 Sadece Devam Edenler</!option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100 fw-semibold" style="border-radius: 8px;">Filtrele</button>
                    </div>
                </form>
            </div>

            <div class="todo-stream">
                @if (Model == null || !Model.Any())
                {
                    <div class="text-center py-5 bg-white shadow-sm rounded-4 border">
                        <i class="bi bi-emoji-smile text-muted display-1 d-block mb-3"></i>
                        <h5 class="text-secondary fw-bold">Buralar Çok Temiz!</h5>
                        <p class="text-muted mb-0">Aradığınız kriterde bir görev bulunamadı veya listeniz boş.</p>
                    </div>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <div class="card todo-card border-0 shadow-sm mb-3 position-relative overflow-hidden bg-white">
                            <div class="position-absolute top-0 start-0 h-100" style="width: 6px; background-color: @(item.IsCompleted ? "#198754" : "#ffc107")"></div>

                            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                                <div class="pe-3">
                                    <div class="d-flex align-items-center gap-2 mb-2">
                                        <span class="badge rounded-pill @(item.IsCompleted ? "bg-success bg-opacity-10 text-success" : "bg-warning bg-opacity-10 text-warning")" style="font-size: 0.75rem;">
                                            @(item.IsCompleted ? "Tamamlandı" : "Devam Ediyor")
                                        </span>
                                        <span class="text-muted" style="font-size: 0.75rem;">
                                            <i class="bi bi-calendar3 me-1"></i> @item.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                                        </span>
                                    </div>
                                    <h5 class="card-title fw-bold mb-2 @(item.IsCompleted ? "text-decoration-line-through text-muted" : "text-dark")">
                                        @item.Title
                                    </h5>
                                    <p class="card-text mb-0 text-secondary @(item.IsCompleted ? "text-decoration-line-through text-opacity-50" : "")" style="font-size: 0.95rem;">
                                        @item.Description
                                    </p>
                                </div>

                                <div class="flex-shrink-0">
                                    <form asp-action="Toggle" method="post">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="title" value="@item.Title" />
                                        <input type="hidden" name="description" value="@item.Description" />
                                        <input type="hidden" name="isCompleted" value="@item.IsCompleted.ToString().ToLower()" />

                                        @if (item.IsCompleted)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success rounded-circle shadow-sm" style="width: 36px; height: 36px; padding: 0;" title="Geri Al">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-success rounded-circle shadow-sm" style="width: 36px; height: 36px; padding: 0;" title="Tamamla">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        }
                                    </form>
                                    <form asp-action="Delete" method="post" class="d-inline ms-2" onsubmit="return confirm('Bu görevi tamamen silmek istediğinize emin misiniz?');">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 36px; height: 36px; padding: 0;" title="Sil">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>